---
import { Image } from "astro:assets";

import HeroImage from "../../assets/img/hero.png";
import OnlyImpage from "../../assets/img/only.png";
import OnlyImpage2 from "../../assets/img/only2.png";
import Button from "../ui/Button.astro";
---

<div
  class="flex flex-col items-center justify-center min-h-[calc(100vh-100px)] relative px-4 py-8 md:py-0 overflow-hidden"
>
  <i
    class="absolute -left-20 md:-left-60 bg-intense-pink size-40 md:size-80 blur-[100px] md:blur-[150px] rounded-full"
  ></i>

  <Image
    class="absolute z-0 opacity-80 w-full md:w-[95%]"
    src={OnlyImpage}
    alt="Background Text"
    loading="eager"
  />

  <div
    class="max-w-7xl flex flex-col md:flex-row justify-between items-center w-full z-10 gap-6 sm:gap-8 md:gap-0"
  >
    <div
      class="flex flex-col items-center md:items-start w-full md:w-fit justify-center order-2 md:order-1"
    >
      <h1
        class="text-intense-pink leading-tight sm:leading-snug md:leading-tight lg:leading-40 text-5xl sm:text-6xl md:text-8xl lg:text-[200px] font-family-nata max-w-2xl text-center md:text-left"
      >
        UNETE A
        <br />
        LOS DEMONIOS
      </h1>

      <p
        class="text-white text-base md:text-xl lg:text-3xl mt-4 sm:mt-6 md:mt-12 text-center md:text-left"
      >
        La comunidad más ganadora de todo internet,
        <br class="hidden sm:block" />
        accede a <span class="text-intense-pink">premios</span> y{" "}
        <span class="text-intense-pink">descuentos</span> exclusivos.
      </p>

      <Button
        class="mt-4 sm:mt-6 md:mt-12 text-base sm:text-lg md:text-2xl lg:text-4xl self-center px-4 sm:px-8 py-2 sm:py-3 border border-transparent hover:bg-black hover:border-white hover:text-intense-pink"
        label="Suscríbete"
        onclick="window.location.href='/registro'"
      />
    </div>

    <div
      class="overflow-hidden sm:overflow-visible group w-full max-w-[280px] sm:max-w-[320px] md:max-w-[400px] lg:max-w-[480px] relative mx-auto md:mx-0 order-1 md:order-2 h-[380px] sm:h-[520px] md:h-[600px] lg:h-[720px]"
    >
      <div
        class="absolute w-full h-[95%] bottom-0 rounded-2xl sm:rounded-3xl overflow-hidden bg-[#000] border-2 border-transparent group-hover:border-intense-pink transition-all duration-300"
      >
        <Image
          class="hero-bg-img absolute w-full h-full object-cover object-center z-0 group-hover:scale-110"
          src={OnlyImpage2}
          alt="Background pattern"
          loading="eager"
        />
        <div
          class="absolute inset-0 bg-[#fd0383] opacity-0 group-hover:opacity-100 mix-blend-multiply transition-opacity duration-300 pointer-events-none"
        >
        </div>
      </div>

      <Image
        class="w-48 md:w-64 lg:w-80 mx-auto relative z-10 group-hover:scale-115 transition-all duration-300"
        src={HeroImage}
        alt="Onlyrgx Valorant"
        loading="eager"
      />

      <i
        class="absolute w-full h-8/10 z-10 bottom-0 bg-linear-to-b from-transparent from-10% via-[#000]/90 via-70% to-[#000] to-90% rounded-b-2xl"
      ></i>

      <div
        class="absolute bottom-3 md:bottom-4 left-0 right-0 text-center z-30"
      >
        <h2
          class="text-white text-4xl sm:text-5xl md:text-7xl lg:text-[140px] font-family-nata font-bold leading-tight sm:leading-snug md:leading-tight lg:leading-25"
        >
          SUSCRÍBETE
        </h2>
        <p class="text-intense-pink text-xs md:text-base lg:text-2xl">
          Y participa por dos sorteos al mes
        </p>
      </div>
    </div>
  </div>
</div>

<style>
  .hero-bg-img {
    filter: invert(1) brightness(0.1);
    transition: all 0.3s ease;
  }

  .group:hover .hero-bg-img {
    filter: invert(1) brightness(1);
  }
</style>
