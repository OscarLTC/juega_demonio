---
import yapeLogo from "../../assets/img/icons/yape.png";

interface Props {
  isOpen?: boolean;
  precio?: number;
}

const { isOpen = false, precio = 6 } = Astro.props;
---

<div
  id="yape-modal"
  class:list={[
    "fixed inset-0 z-50 flex items-center justify-center",
    isOpen ? "flex" : "hidden"
  ]}
>
  <div class="absolute inset-0 bg-black/53" data-close-modal></div>

  <div class="relative w-[427px] bg-[#FFE6F3] rounded-[10px] p-8">
    <button
      type="button"
      data-close-modal
      class="absolute top-4 right-4 text-[#4D4D4D] hover:text-[#202020] transition-colors"
    >
      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
      </svg>
    </button>

    <h2 class="text-center font-family-display font-bold text-[45.67px] leading-[55px] text-[#FD0383] mb-4">
      DEMONI@
    </h2>

    <p class="text-center text-[#4D4D4D] text-sm mb-6">
      Ingresa a la <span class="font-bold">App de Yape</span> y copia el código para<br/>
      terminar tu compra.
    </p>

    <form id="yape-form" class="space-y-4">
      <div>
        <label class="block text-[#FE56AC] font-medium text-[15px] mb-2">
          Ingresa tu celular de yape
        </label>
        <input
          type="tel"
          name="celular-yape"
          placeholder="Ingresa tu celular"
          maxlength="9"
          class="w-full h-[43px] px-4 bg-[#FAF9F9] border border-[#FE8BC6] rounded-[7px] text-sm text-[#4D4D4D] placeholder:text-[#4D4D4D]/70 focus:outline-none focus:border-[#FD0383]"
          required
        />
      </div>

      <div>
        <label class="block text-[#FE56AC] font-medium text-[15px] mb-2">
          Ingresa tu código de aprobación
        </label>
        <input
          type="text"
          name="codigo-yape"
          placeholder="Ingresa tu código"
          class="w-full h-[43px] px-4 bg-[#FAF9F9] border border-[#FE8BC6] rounded-[7px] text-sm text-[#4D4D4D] placeholder:text-[#4D4D4D]/70 focus:outline-none focus:border-[#FD0383]"
          required
        />
        <p class="text-[11px] text-[#4D4D4D] mt-1">
          Encuéntralo en el menú de YAPE
        </p>
      </div>

      <div id="yape-error" class="hidden text-red-500 text-xs text-center"></div>

      <button
        type="submit"
        class="w-[290px] mx-auto block h-[34px] bg-[#FD359C] rounded-[7px] text-white font-family-display font-bold text-xl hover:bg-[#FD359C]/90 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
      >
        YAPEAR S/.<span id="yape-precio">{precio}.00</span>
      </button>
    </form>

    <div class="flex justify-center mt-6">
      <img
        src={yapeLogo.src}
        alt="Yape"
        class="h-[67px] w-auto object-contain"
      />
    </div>
  </div>
</div>

<script>
  import axios from "axios";

  const API_BASE_URL = import.meta.env.PUBLIC_API_URL || "/api";

  function initYapeModal() {
    const modal = document.getElementById('yape-modal');
    const closeButtons = modal?.querySelectorAll('[data-close-modal]');
    const form = document.getElementById('yape-form') as HTMLFormElement;
    const yapeError = document.getElementById('yape-error');

    closeButtons?.forEach(btn => {
      btn.addEventListener('click', () => {
        modal?.classList.add('hidden');
        modal?.classList.remove('flex');
      });
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal?.classList.contains('hidden')) {
        modal?.classList.add('hidden');
        modal?.classList.remove('flex');
      }
    });

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();

      const order = (window as any).__pendingOrder;
      if (!order?.id) {
        if (yapeError) {
          yapeError.textContent = 'No se encontró la orden. Intenta de nuevo.';
          yapeError.classList.remove('hidden');
        }
        return;
      }

      const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = 'PROCESANDO...';
      }

      if (yapeError) {
        yapeError.classList.add('hidden');
        yapeError.textContent = '';
      }

      try {
        const token = localStorage.getItem('accessToken');
        await axios.post(
          `${API_BASE_URL}/webhooks/simulate/${order.id}?paymentMethod=yape`,
          {},
          { headers: token ? { Authorization: `Bearer ${token}` } : {} },
        );

        // Payment successful
        window.location.href = '/app/dashboard';
      } catch (err: any) {
        const message = err.response?.data?.message || 'Error al procesar el pago con Yape';
        if (yapeError) {
          yapeError.textContent = message;
          yapeError.classList.remove('hidden');
        }
      } finally {
        if (submitBtn) {
          submitBtn.disabled = false;
          const selectedPlan = localStorage.getItem('selectedPlan');
          submitBtn.innerHTML = `YAPEAR S/.<span id="yape-precio">${selectedPlan === 'mensual' ? '6.00' : '16.00'}</span>`;
        }
      }
    });
  }

  (window as any).openYapeModal = () => {
    const modal = document.getElementById('yape-modal');
    const selectedPlan = localStorage.getItem('selectedPlan');
    const precioSpan = document.getElementById('yape-precio');
    if (precioSpan) {
      precioSpan.textContent = selectedPlan === 'mensual' ? '6.00' : '16.00';
    }
    const yapeError = document.getElementById('yape-error');
    if (yapeError) {
      yapeError.classList.add('hidden');
      yapeError.textContent = '';
    }
    modal?.classList.remove('hidden');
    modal?.classList.add('flex');
  };

  initYapeModal();
  document.addEventListener('astro:after-swap', initYapeModal);
</script>
